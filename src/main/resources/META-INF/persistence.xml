<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="
               https://jakarta.ee/xml/ns/persistence
               https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="storePU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.example.storemanagement.model.entity.Product</class>
        <class>com.example.storemanagement.model.entity.Batch</class>
        <class>com.example.storemanagement.model.entity.Branch</class>
        <class>com.example.storemanagement.model.entity.Category</class>
        <class>com.example.storemanagement.model.entity.Customer</class>
        <class>com.example.storemanagement.model.entity.Employee</class>
        <class>com.example.storemanagement.model.entity.InvoiceDetail</class>
        <class>com.example.storemanagement.model.id.InvoiceDetailId</class>
        <class>com.example.storemanagement.model.entity.Supplier</class>
        <class>com.example.storemanagement.model.entity.Invoice</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/storemanagement?useSSL=false&amp;serverTimezone=Asia/Ho_Chi_Minh&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="12345"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="validate"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>